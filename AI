<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TeachBek</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #0F1117; color: #D4D8E8; font-family: Georgia, serif; height: 100vh; display: flex; overflow: hidden; }

  #sidebar {
    width: 260px; min-width: 260px;
    background: #13162A; display: flex; flex-direction: column;
    border-right: 1px solid #252840;
    transition: width 0.25s ease, min-width 0.25s ease; overflow: hidden;
  }
  #sidebar.collapsed { width: 0; min-width: 0; border-right: none; }
  #sidebar-header { padding: 16px 14px 12px; border-bottom: 1px solid #252840; }
  #sidebar-header span { font-size: 12px; color: #7A8099; text-transform: uppercase; letter-spacing: 1px; white-space: nowrap; }
  #new-chat-btn {
    background: #4ECDC4; color: #0F1117; border: none;
    padding: 9px 14px; margin: 10px 14px; width: calc(100% - 28px);
    border-radius: 7px; font-size: 13px; font-weight: bold;
    font-family: Georgia, serif; cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: background 0.15s; white-space: nowrap;
  }
  #new-chat-btn:hover { background: #3ABAB2; }
  #chat-list { flex: 1; overflow-y: auto; padding: 4px 8px 16px; display: flex; flex-direction: column; gap: 2px; }
  #chat-list::-webkit-scrollbar { width: 4px; }
  #chat-list::-webkit-scrollbar-thumb { background: #252840; border-radius: 4px; }
  .chat-item { display: flex; align-items: center; gap: 8px; padding: 9px 10px; border-radius: 7px; cursor: pointer; transition: background 0.15s; min-width: 0; }
  .chat-item:hover { background: #1E2240; }
  .chat-item.active { background: #252840; }
  .chat-item-info { flex: 1; min-width: 0; }
  .chat-item-title { font-size: 13px; color: #C8CDE0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .chat-item.active .chat-item-title { color: #E8D5A3; }
  .chat-item-date { font-size: 10px; color: #4A5070; margin-top: 1px; }
  .chat-item-del { background: none; border: none; color: #4A5070; cursor: pointer; font-size: 14px; padding: 2px 4px; border-radius: 4px; flex-shrink: 0; opacity: 0; transition: opacity 0.15s, color 0.15s; }
  .chat-item:hover .chat-item-del { opacity: 1; }
  .chat-item-del:hover { color: #FF6B6B; }
  .sidebar-section-label { font-size: 10px; color: #3A4060; text-transform: uppercase; letter-spacing: 1px; padding: 10px 10px 4px; white-space: nowrap; }
  .empty-sidebar { padding: 24px 16px; text-align: center; color: #3A4060; font-size: 12px; line-height: 1.6; }

  #main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  #header { background: #1A1D2E; padding: 14px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #252840; }
  #toggle-sidebar { background: none; border: none; color: #7A8099; font-size: 18px; cursor: pointer; padding: 4px; border-radius: 4px; transition: color 0.15s; }
  #toggle-sidebar:hover { color: #E8D5A3; }
  #header .avatar { font-size: 28px; }
  #header-info { flex: 1; }
  #header h1 { font-size: 18px; color: #E8D5A3; }
  #header p { font-size: 11px; color: #7A8099; margin-top: 1px; }
  #chat-title-display { font-size: 11px; color: #4ECDC4; margin-top: 1px; font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; }

  #chat { flex: 1; overflow-y: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 16px; }
  #chat::-webkit-scrollbar { width: 5px; }
  #chat::-webkit-scrollbar-thumb { background: #252840; border-radius: 4px; }
  .msg { display: flex; flex-direction: column; gap: 4px; max-width: 78%; }
  .msg.professor { align-self: flex-start; }
  .msg.user { align-self: flex-end; }
  .msg-label { font-size: 11px; color: #7A8099; }
  .msg.user .msg-label { text-align: right; color: #4ECDC4; }
  .msg-bubble { padding: 12px 16px; border-radius: 12px; font-size: 14px; line-height: 1.6; white-space: pre-wrap; }
  .msg.professor .msg-bubble { background: #1A1D2E; border: 1px solid #252840; color: #D4D8E8; border-radius: 4px 12px 12px 12px; }
  .msg.user .msg-bubble { background: #252840; color: #B8E0DC; border-radius: 12px 4px 12px 12px; }
  .correction { color: #FFB347; }
  .typing { color: #5A6080; font-style: italic; font-size: 13px; padding: 8px 0; }
  .error-msg { color: #FF6B6B; font-size: 13px; padding: 8px 12px; background: #1A1020; border: 1px solid #3A1020; border-radius: 8px; }

  #bottom { background: #1A1D2E; padding: 14px 20px; border-top: 1px solid #252840; display: flex; gap: 10px; align-items: flex-end; }
  #input { flex: 1; background: #252840; border: 1px solid #3A3D52; color: #E8EAF6; padding: 10px 14px; border-radius: 8px; font-size: 14px; font-family: Georgia, serif; resize: none; min-height: 44px; max-height: 120px; outline: none; }
  #input:focus { border-color: #4ECDC4; }
  #sendbtn { background: #4ECDC4; color: #0F1117; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: bold; font-family: Georgia, serif; height: 44px; transition: background 0.15s; }
  #sendbtn:hover { background: #3ABAB2; }
  #sendbtn:disabled { background: #3A3D52; color: #7A8099; cursor: not-allowed; }
  #hint { text-align: center; font-size: 11px; color: #3A3D52; padding: 5px; background: #0F1117; }
</style>
</head>
<body>

<div id="sidebar">
  <div id="sidebar-header"><span>💬 История чатов</span></div>
  <button id="new-chat-btn" onclick="newChat()">✏️ Новый чат</button>
  <div id="chat-list"></div>
</div>

<div id="main">
  <div id="header">
    <button id="toggle-sidebar" onclick="toggleSidebar()">☰</button>
    <div class="avatar">🎓</div>
    <div id="header-info">
      <h1>TeachBek</h1>
      <p>Your Personal AI English Teacher</p>
      <div id="chat-title-display"></div>
    </div>
  </div>
  <div id="chat"></div>
  <div id="bottom">
    <textarea id="input" placeholder="Write in English or Russian..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
    <button id="sendbtn" onclick="sendMessage()">Send ➤</button>
  </div>
  <div id="hint">Enter — отправить &nbsp;•&nbsp; Shift+Enter — новая строка</div>
</div>

<script>
// ВАШ GROQ КЛЮЧ:
const API_KEY = "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";

let history = [], thinking = false, currentChatId = null, sidebarOpen = true;

const SYSTEM = `You are TeachBek, a warm and encouraging English teacher. The student speaks Russian and is learning English.

YOUR ROLE:
- Chat naturally in English
- If they write in Russian, respond in English and gently encourage them to try in English
- ALWAYS correct grammar, spelling, vocabulary mistakes politely
- Use this format for corrections: ✏️ Correction: "wrong" → "correct" — brief explanation
- Praise good English with 🌟
- Keep responses short (2-4 sentences + corrections)
- Ask follow-up questions to keep conversation going

Start by greeting the student warmly and asking about their English level.`;

function getChats() { try { return JSON.parse(localStorage.getItem("teachbek_chats") || "{}"); } catch { return {}; } }
function saveChats(c) { try { localStorage.setItem("teachbek_chats", JSON.stringify(c)); } catch(e) {} }
function getChatMeta() { try { return JSON.parse(localStorage.getItem("teachbek_meta") || "[]"); } catch { return []; } }
function saveChatMeta(m) { try { localStorage.setItem("teachbek_meta", JSON.stringify(m)); } catch(e) {} }
function generateId() { return "chat_" + Date.now() + "_" + Math.random().toString(36).slice(2,7); }

function formatDate(ts) {
  const d = Date.now() - ts;
  if (d < 60000) return "только что";
  if (d < 3600000) return Math.floor(d/60000) + " мин назад";
  if (d < 86400000) return Math.floor(d/3600000) + " ч назад";
  if (d < 604800000) return Math.floor(d/86400000) + " дн назад";
  return new Date(ts).toLocaleDateString("ru-RU", { day: "numeric", month: "short" });
}
function esc(s) { return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }

function renderSidebar() {
  try {
    const meta = getChatMeta(), list = document.getElementById("chat-list");
    list.innerHTML = "";
    if (!meta.length) { list.innerHTML = `<div class="empty-sidebar">Нет сохранённых чатов.<br>Начните новый чат!</div>`; return; }
    const now = Date.now(), today = [], week = [], older = [];
    [...meta].sort((a,b) => b.updatedAt - a.updatedAt).forEach(m => {
      const d = now - m.updatedAt;
      if (d < 86400000) today.push(m); else if (d < 604800000) week.push(m); else older.push(m);
    });
    function grp(label, items) {
      if (!items.length) return;
      const l = document.createElement("div"); l.className = "sidebar-section-label"; l.textContent = label; list.appendChild(l);
      items.forEach(m => {
        const div = document.createElement("div");
        div.className = "chat-item" + (m.id === currentChatId ? " active" : "");
        div.innerHTML = `<div class="chat-item-info"><div class="chat-item-title">${esc(m.title)}</div><div class="chat-item-date">${formatDate(m.updatedAt)}</div></div><button class="chat-item-del" onclick="deleteChat(event,'${m.id}')">✕</button>`;
        div.addEventListener("click", e => { if (!e.target.classList.contains("chat-item-del")) loadChat(m.id); });
        list.appendChild(div);
      });
    }
    grp("Сегодня", today); grp("На этой неделе", week); grp("Раньше", older);
  } catch(e) { console.error("renderSidebar error:", e); }
}

function newChat() {
  try {
    saveCurrent();
    currentChatId = generateId(); history = [];
    document.getElementById("chat").innerHTML = "";
    document.getElementById("chat-title-display").textContent = "";
    renderSidebar(); getReply();
  } catch(e) { console.error("newChat error:", e); }
}

function loadChat(id) {
  try {
    saveCurrent();
    const chats = getChats(); if (!chats[id]) return;
    currentChatId = id; history = chats[id].history || [];
    const chat = document.getElementById("chat"); chat.innerHTML = "";
    (chats[id].messages || []).forEach(m => addMessage(m.role, m.text, false));
    const meta = getChatMeta().find(m => m.id === id);
    document.getElementById("chat-title-display").textContent = meta ? meta.title : "";
    renderSidebar(); chat.scrollTop = chat.scrollHeight;
  } catch(e) { console.error("loadChat error:", e); }
}

function saveCurrent() {
  try {
    if (!currentChatId || history.length === 0) return;
    const messages = [];
    document.querySelectorAll("#chat .msg").forEach(el => {
      const role = el.classList.contains("professor") ? "professor" : "user";
      const text = Array.from(el.querySelectorAll(".msg-bubble span")).map(s => s.textContent).join("").replace(/\n$/, "");
      messages.push({ role, text });
    });
    const chats = getChats(); chats[currentChatId] = { history, messages }; saveChats(chats);
    let meta = getChatMeta(); const ex = meta.find(m => m.id === currentChatId); const title = deriveTitle();
    if (ex) { ex.title = title; ex.updatedAt = Date.now(); }
    else meta.push({ id: currentChatId, title, updatedAt: Date.now(), createdAt: Date.now() });
    saveChatMeta(meta);
  } catch(e) { console.error("saveCurrent error:", e); }
}

function deriveTitle() {
  const f = history.find(m => m.role === "user");
  if (f) { const t = f.content.trim().replace(/\n/g," "); return t.length > 40 ? t.slice(0,40)+"…" : t; }
  return "Новый чат";
}

function deleteChat(e, id) {
  e.stopPropagation();
  const chats = getChats(); delete chats[id]; saveChats(chats);
  let meta = getChatMeta().filter(m => m.id !== id); saveChatMeta(meta);
  if (currentChatId === id) {
    currentChatId = null; history = [];
    document.getElementById("chat").innerHTML = "";
    document.getElementById("chat-title-display").textContent = "";
    if (!meta.length) { newChat(); return; }
    loadChat([...meta].sort((a,b) => b.updatedAt - a.updatedAt)[0].id);
  }
  renderSidebar();
}

function toggleSidebar() {
  sidebarOpen = !sidebarOpen;
  document.getElementById("sidebar").classList.toggle("collapsed", !sidebarOpen);
}

function handleKey(e) { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); } }
function autoResize(el) { el.style.height = "auto"; el.style.height = Math.min(el.scrollHeight,120)+"px"; }

function addMessage(role, text, save = true) {
  try {
    const chat = document.getElementById("chat");
    const div = document.createElement("div"); div.className = "msg " + role;
    const label = document.createElement("div"); label.className = "msg-label";
    label.textContent = role === "professor" ? "🎓 TeachBek" : "👤 You";
    const bubble = document.createElement("div"); bubble.className = "msg-bubble";
    text.split("\n").forEach(line => {
      const span = document.createElement("span");
      if (line.trim().startsWith("✏️")) span.className = "correction";
      span.textContent = line + "\n"; bubble.appendChild(span);
    });
    div.appendChild(label); div.appendChild(bubble); chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
    if (save) saveCurrent();
  } catch(e) { console.error("addMessage error:", e); }
}

function showTyping() {
  const chat = document.getElementById("chat");
  const div = document.createElement("div"); div.id = "typing"; div.className = "typing";
  div.textContent = "🎓 TeachBek is typing..."; chat.appendChild(div); chat.scrollTop = chat.scrollHeight;
}
function removeTyping() { const t = document.getElementById("typing"); if (t) t.remove(); }

async function sendMessage() {
  if (thinking) return;
  const input = document.getElementById("input"); const text = input.value.trim(); if (!text) return;
  input.value = ""; input.style.height = "auto";
  addMessage("user", text); history.push({ role: "user", content: text }); getReply();
}

async function getReply() {
  thinking = true;
  document.getElementById("sendbtn").disabled = true;
  showTyping();
  try {
    const res = await fetch("https://api.groq.com/openai/v1/chat/completions", {
      method: "POST",
      headers: { "Content-Type": "application/json", "Authorization": "Bearer " + API_KEY },
      body: JSON.stringify({
        model: "llama-3.3-70b-versatile",
        max_tokens: 1024,
        messages: [{ role: "system", content: SYSTEM }, ...history]
      })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error.message);
    const reply = data.choices[0].message.content;
    history.push({ role: "assistant", content: reply });
    removeTyping();
    addMessage("professor", reply);
    const meta = getChatMeta(); const m = meta.find(x => x.id === currentChatId);
    if (m) { m.title = deriveTitle(); m.updatedAt = Date.now(); saveChatMeta(meta); }
    renderSidebar();
    const t = deriveTitle();
    document.getElementById("chat-title-display").textContent = t === "Новый чат" ? "" : t;
  } catch(e) {
    removeTyping();
    const chat = document.getElementById("chat");
    const div = document.createElement("div");
    div.className = "error-msg";
    div.textContent = "⚠️ Ошибка: " + e.message + " — проверьте API ключ на console.groq.com/keys";
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
  }
  thinking = false;
  document.getElementById("sendbtn").disabled = false;
  document.getElementById("input").focus();
}

window.onload = function() {
  try {
    const meta = getChatMeta();
    if (meta.length > 0) {
      loadChat([...meta].sort((a,b) => b.updatedAt - a.updatedAt)[0].id);
    } else {
      newChat();
    }
  } catch(e) {
    console.error("onload error:", e);
    // Даже если что-то сломалось — показываем интерфейс
    currentChatId = generateId();
    renderSidebar();
  }
};
</script>
</body>
</html>
